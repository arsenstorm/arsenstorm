{
	"dependencies": {
		"@astrojs/cloudflare": "^14.1.3",
		"@astrojs/markdown-remark": "^7.0.0",
		"@astrojs/mdx": "^7.0.3",
		"@astrojs/react": "^6.0.1",
		"@astrojs/sitemap": "^3.7.3",
		"@tailwindcss/vite": "^4.3.3",
		"@web-kits/audio": "^0.1.0",
		"astro": "^7.1.1",
		"cnfast": "^0.0.8",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"hls-video-element": "^1.5.11",
		"img-fx": "^0.3.1",
		"lucide-react": "^0.545.0",
		"media-chrome": "^4.19.2",
		"motion": "^12.40.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwindcss": "^4.3.3",
		"three": "^0.184.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@tailwindcss/typography": "^0.5.16",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/bun": "^1.3.14",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"@types/mdx": "^2.0.13",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"eslint-mdx": "^3.7.1",
		"eslint-plugin-mdx": "^3.7.1",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"prettier": "^3.8.3",
		"puppeteer": "latest",
		"rehype-pretty-code": "^0.14.3",
		"remark-gfm": "^4.0.1",
		"typescript": "^7.0.2",
		"ultracite": "7.6.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.10",
		"wrangler": "^4.111.0"
	},
	"name": "arsenstorm",
	"scripts": {
		"dev": "bun run generate:weather-snapshot && astro dev --port 3000",
		"dev:worker": "wrangler dev --port 8787",
		"build": "bun run generate:map-snapshots && astro build",
		"generate:og": "bun scripts/generate-og-assets.ts",
		"generate:map-snapshots": "bun scripts/generate-map-snapshots.ts",
		"generate:weather-snapshot": "bun scripts/generate-weather-snapshot.ts",
		"preview": "astro preview",
		"test": "vitest run",
		"typecheck": "bunx tsc --noEmit",
		"format": "biome format && prettier --write \"**/*.mdx\"",
		"lint": "biome lint",
		"check": "ultracite check",
		"deploy": "bun run build && bun run generate:og && wrangler deploy",
		"deploy:preview": "bun run build && bun run generate:og && wrangler versions upload",
		"cf:types": "wrangler types workers.d.ts --env-interface CloudflareBindings",
		"fix": "ultracite fix",
		"prepare": "husky"
	},
	"type": "module",
	"private": true,
	"imports": {
		"#/*": "./src/*"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lightningcss"
		]
	}
}
