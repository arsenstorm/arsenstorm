{
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.26.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@web-kits/audio": "^0.1.0",
    "clsx": "^2.1.1",
    "img-fx": "^0.3.1",
    "lucide-react": "^0.545.0",
    "motion": "^12.40.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint-mdx": "^3.7.1",
    "eslint-plugin-mdx": "^3.7.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.3",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.7.2",
    "ultracite": "7.6.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.5",
    "wrangler": "^4.70.0"
  },
  "name": "arsenstorm",
  "scripts": {
    "dev": "bun run generate:weather-snapshot && vite dev --port 3000",
    "build": "bun run generate:map-snapshots && vite build",
    "generate:map-snapshots": "bun scripts/generate-map-snapshots.ts",
    "generate:weather-snapshot": "bun scripts/generate-weather-snapshot.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format && prettier --write \"**/*.mdx\"",
    "lint": "biome lint",
    "check": "ultracite check",
    "deploy": "bun run build && wrangler deploy",
    "cf:types": "wrangler types workers.d.ts --env-interface CloudflareBindings",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "type": "module",
  "private": true,
  "imports": {
    "#/*": "./src/*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
