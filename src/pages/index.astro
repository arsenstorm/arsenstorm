---
export const prerender = true;

import { ExperienceList } from "#/components/experience-list.tsx";
import { ItemGroup } from "#/components/item-group.tsx";
import { textLinkClass } from "#/components/link.tsx";
import { PageHeading } from "#/components/page-heading.tsx";
import { Section } from "#/components/section.tsx";
import { Writing } from "#/components/writing.tsx";
import Clipboard from "#/icons/clipboard.tsx";
import ClipboardCheck from "#/icons/clipboard-check.tsx";
import BaseLayout from "#/layouts/base-layout.astro";
import { getExperience } from "#/lib/experience";
import { PROJECTS } from "#/lib/projects.ts";
import { getWriteups } from "#/lib/writeups";

const TITLE = "Arsen Shkrumelyak";
const DESCRIPTION = "I build software with care.";

const ELSEWHERE: { label: string; href: string; copy?: string }[] = [
	{
		label: "Email",
		href: "mailto:arsen@shkrumelyak.com",
		copy: "arsen@shkrumelyak.com",
	},
	{ label: "GitHub", href: "https://github.com/arsenstorm" },
	{ label: "Twitter", href: "https://x.com/arsenstorm" },
	{ label: "CV", href: "/cv" },
];

const writeups = await getWriteups();

const experience = (await getExperience()).filter(
	(item) => item.kind === "experience"
);

const featuredProjects = PROJECTS.filter((project) => project.featured);
---

<BaseLayout description={DESCRIPTION} title={TITLE}>
  <main class="mx-auto max-w-xl space-y-12 px-6 py-24">
    <PageHeading description={DESCRIPTION} noHomeLink title={TITLE} />

    <Section
      cta={experience.length > 2
        ? { label: "View all", href: "/experience" }
        : undefined}
      title="Experience"
    >
      <ExperienceList items={experience} />
    </Section>

    <Section cta={{ label: "View all", href: "/projects" }} title="Projects">
      <ItemGroup id="projects-list" items={featuredProjects} showAll={false} />
    </Section>

    <Writing items={writeups} />

    <Section title="Elsewhere">
      <ul class="flex flex-col gap-2">
        {
          ELSEWHERE.map((item) => {
            const external = item.href.startsWith("http");
            return (
              <li class="flex items-center gap-0.5 text-sm">
                <a
                  class={textLinkClass}
                  href={item.href}
                  rel={external ? "noopener noreferrer" : undefined}
                  target={external ? "_blank" : undefined}
                >
                  {item.label}
                </a>
                {item.copy ? (
                  <button
                    aria-label={`Copy ${item.copy}`}
                    class="group/copy flex size-5 translate-y-px items-center justify-center rounded-md text-neutral-400 transition-colors hover:text-neutral-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-950/30 dark:text-neutral-500 dark:focus-visible:ring-white/30 dark:hover:text-neutral-50"
                    data-copy={item.copy}
                    type="button"
                  >
                    <Clipboard className="size-3 group-data-copied/copy:hidden" />
                    <ClipboardCheck className="hidden size-3 group-data-copied/copy:block" />
                  </button>
                ) : null}
              </li>
            );
          })
        }
      </ul>
    </Section>
  </main>
</BaseLayout>

<script>
  const RESET_DELAY = 2000;

  for (const button of document.querySelectorAll<HTMLButtonElement>(
    "[data-copy]",
  )) {
    let timeout: ReturnType<typeof setTimeout> | undefined;
    button.addEventListener("click", async () => {
      await navigator.clipboard.writeText(button.dataset.copy ?? "");
      button.dataset.copied = "";
      clearTimeout(timeout);
      timeout = setTimeout(() => {
        delete button.dataset.copied;
      }, RESET_DELAY);
    });
  }
</script>
