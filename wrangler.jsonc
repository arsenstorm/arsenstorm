{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "arsenstorm",
  "compatibility_date": "2026-04-22",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/index.ts",
  "triggers": {
    // Runs every 6 hours to refresh GitHub contribution stats
    "crons": ["0 */6 * * *"]
  },
  "kv_namespaces": [
    {
      "binding": "STATS",
      // Replace with the output of: wrangler kv namespace create STATS
      "id": "00000000000000000000000000000000"
    }
  ]
}
